FFMPEG_PATH=
FFPROBE_PATH=
FILE_STORAGE_ROOT=
VIDEO_PREVIEW_MAX_WIDTH=1280
VIDEO_PREVIEW_TIMEOUT_SECONDS=600

APP_NAME=MarkUp API
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=markup
DATABASE_URL=sqlite:///./markup.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
FRONTEND_OAUTH_CALLBACK_URL=https://www.markuplabel.cn/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://www.markuplabel.cn/api/v1/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.markuplabel.cn/api/v1/auth/oauth/google/callback
HUGGINGFACE_CLIENT_ID=
HUGGINGFACE_CLIENT_SECRET=
HUGGINGFACE_REDIRECT_URI=https://www.markuplabel.cn/api/v1/auth/oauth/huggingface/callback

# Security hardening. Use strong random values in production.
PASSWORD_PEPPER=
VERIFICATION_CODE_PEPPER=

# SMTP email delivery. Set SMTP_ENABLED=true to send real emails.
SMTP_ENABLED=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=markuplabel@163.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=markuplabel@163.com
SMTP_FROM_NAME=MarkUp
SMTP_USE_TLS=false
SMTP_USE_SSL=true
